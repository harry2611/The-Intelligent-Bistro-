    "export:android": "npm run export:android --workspace mobile",
    "test": "npm run test --workspace server"
  },
  "overrides": {
    "@xmldom/xmldom": "0.9.10",
    "@react-native/virtualized-lists": "0.81.5",
    "postcss": "8.5.14",
    "react": "19.1.0",
    "react-native": "0.81.5",
    "tar": "7.5.15"
  }
}
