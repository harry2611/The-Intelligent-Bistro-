{
  "name": "viridien-order-assistant",
  "private": true,
  "version": "1.0.0",
  "description": "The Intelligent Bistro Expo mobile restaurant ordering app with a Node.js conversational cart API.",
  "workspaces": [
    "mobile",
    "server"
  ],
  "scripts": {
    "dev": "npm run dev --workspace server",
